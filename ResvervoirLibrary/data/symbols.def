#CoJack Formula Symbol Definitions (syntax: [symbol]=[format],[description])
#Thu Dec 15 11:01:32 CET 2016
asin=asin(value);Arcsine function;
cos=cos(); ;
PI=PI; ;
floor=floorDouble); ;
dt=dt;Time in seconds from simulation start;
true=true; ;
avg=avg(); ;
log=log(); Natural Logarithm, logaritmic function base E;
sin=sin(); ;
E=E;Nepero Number ;
eparam=eparam(key);Event parameter, indexed by the given key string;
strget=strget(); ;
sum=sum();Returns the summation of given arguments;
cpval=cpval;Cognitive Parameter base value ;
eexp=eexp(idx);Exposure of the event at the idx integer given;
max=max(); ;
strcontains=strcontains(str1,str2); Boolean function, tells if str1 contains str2;
random=random(); ;
prod=prod(); ;
ceil=ceil(Double); ;
pow=pow();Power ;
abs=abs();Absolute value ;
atan=atan(); Arco Tangent;
log10=log10(); Logaritmic function base 10;
esiz=esiz;Total events number;
sqrt=sqrt(); Square root;
radTodeg=radTodeg(Double); Radiant to Degrees;
logn=logn(b,v); Logaritmic function base b for value v;
int=int(Double); Integer;
tan=tan(); Tangent;
t=t;Current time in seconds;
strlen=strlen();The length of the given string ;
reservoir=reservoir; ;
false=false; boolean constant;
et=et(idx);Time of the event at the idx integer given ;
SUM=SUM(index,base,limit,f);Summation for function f (string), considering the given index (string), starting from base (int), ceiling to limit (int);
round=round(Double); Round the given number;
degTorad=degTorad(Double); Degrees to Radiant;
acos=acos();Arc Cosine ;
min=min();Minimum between args;
exp=exp();Exponential function;
