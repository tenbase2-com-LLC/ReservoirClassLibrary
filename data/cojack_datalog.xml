<?xml version="1.0" encoding="UTF-8"?>

<!--
	To record a new datalog insert a new tag named datalog under the datalogs element.
	The datalog element will contain key elements specifing what to trace.
	ie:
		<datalogs>
			<datalog file="file.txt">
				<key agent="goofy" class="disney" object="*"/>
			</datalog>
		</datalogs>

	XML syntax summary:
    - datalogs:
    	maxTraceLineRecord: how many table rows to show in the datalog tabs
    	- datalog:
    		file: the file to print the datalog to (default null)
    		showOnGUI: not implemented yet, should allow logging without gui
    		- plot:
    			x: index of value data for x axis
    			y: index of value data for y axis
    		- key:
    			agent: the agent list to log, separated by a comma char (default *)
    			class: the class list to log, separated by a comma char (default *)
    			object: the object list to log, separated by a comma char (default *)
    			
    Notes: 
    	- * (JOLLY_ELEMENT) is meant to match with every datalog element
    	- when default is specified, the attribute is optional
    	- all elements (but the datalogs one) are unbounded (0..*) and specifically:
    		i) for each plot entry, a plot will be drown
    		ii) each key is merged with the previous one creating list of entries (merging * always give *)
    	- if no key is specified, a jolly key will be used, matching every datalog (like agent="*" class="*" object="*")
-->

<datalogs maxTraceLineRecord="100">
 	<datalog>
 		<plot x="0" y="3"/>
 		<key agent="*" class="CognitiveParameter" object="DEFAULT_ACTION_TIME"/>
 	</datalog>
	<datalog>
 		<plot x="0" y="3"/>
 		<key agent="*" class="CognitiveParameter" object="PLAN_VALUE/WaitPlan"/>
 	</datalog>
</datalogs>
